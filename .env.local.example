NEXT_PUBLIC_SUPABASE_URL=https://sdgdeuhligplyemhuirn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Telegram bot username exposed to the client for the OTP deep-link button
# (https://t.me/<username>?start=verify_<phone>). Non-sensitive public config.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=ozauth_bot

# Founder's HUMAN contact account on Telegram — a real person you can DM, NOT the
# auth bot above. This is where "связаться с создателем" (on /help, empty/error
# states, and the in-deal catch-all) lands. Set it to the operator's own handle,
# without the leading @. Honesty about scale is the point: this is the maker of
# öz, not a support desk.
NEXT_PUBLIC_OZ_CONTACT_TELEGRAM=hello_a1an

# Optional founder contact email. Telegram is the real channel for this audience;
# email is optional decoration. Leave blank/unset and the email row is simply not
# rendered — no empty contact line.
NEXT_PUBLIC_OZ_CONTACT_EMAIL=
